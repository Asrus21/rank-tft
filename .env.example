# Variáveis de ambiente — Railway

# Riot API Key (Personal ou Development)
# A Personal Key registrada para LoL também serve para TFT — mesma key, endpoints diferentes.
RIOT_API_KEY=RGAPI-xxxx-xxxx-xxxx-xxxx

# PostgreSQL (Railway injeta automaticamente quando você adiciona o addon Postgres)
DATABASE_URL=postgresql://user:pass@host:port/db

# Origens permitidas pelo CORS — separadas por vírgula
CORS_ORIGIN=https://www.asrus.app,https://asrus.app,https://rank-tft.vercel.app

# Ambiente
NODE_ENV=production

# Porta (Railway injeta automaticamente, mas use 3000 para dev local)
PORT=3000
